<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- =====================================================================
         Sidebar ListBoxItem — Icon + Name layout
         Each item's Content is expected to be a model with an Icon (ImageSource
         or Geometry) and a Name (string), or the DataTemplate can be overridden
         by the consumer.  A generic text-only fallback is provided here via the
         default ContentPresenter.
         ===================================================================== -->

    <!-- Active indicator bar on the left edge -->
    <Style x:Key="SidebarActiveIndicator" TargetType="Border">
        <Setter Property="Width"            Value="3" />
        <Setter Property="Background"       Value="{StaticResource AccentBrush}" />
        <Setter Property="CornerRadius"     Value="0,1,1,0" />
        <Setter Property="Visibility"       Value="Collapsed" />
    </Style>

    <!-- =====================================================================
         SidebarListBoxItem
         ===================================================================== -->
    <Style x:Key="SidebarListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="Foreground"       Value="{StaticResource ForegroundBrush}" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="Padding"          Value="12,8" />
        <Setter Property="MinHeight"        Value="36" />
        <Setter Property="FontSize"         Value="13" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <!-- Selection / hover background -->
                        <Border x:Name="HoverBg"
                                Background="Transparent"
                                SnapsToDevicePixels="True" />

                        <!-- Left edge accent indicator -->
                        <Border x:Name="ActiveBar"
                                Width="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                CornerRadius="0,1,1,0"
                                Background="{StaticResource AccentBrush}"
                                Visibility="Collapsed" />

                        <!-- Content area with left padding to clear the indicator -->
                        <Border Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Icon column: fixed width, centred -->
                                    <ColumnDefinition Width="22" />
                                    <!-- Gap -->
                                    <ColumnDefinition Width="8" />
                                    <!-- Label -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon slot: the DataTemplate or ContentPresenter
                                     for the Icon property of the bound item.
                                     When the item exposes an Icon property of type
                                     ImageSource the Image element below will display it.
                                     Override this DataTemplate for other icon types. -->
                                <ContentPresenter x:Name="IconPresenter"
                                                  Grid.Column="0"
                                                  Content="{Binding Icon,
                                                             RelativeSource={RelativeSource TemplatedParent},
                                                             TargetNullValue={x:Null}}"
                                                  Width="16" Height="16"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />

                                <!-- Name / label -->
                                <TextBlock x:Name="ItemLabel"
                                           Grid.Column="2"
                                           Text="{Binding Name,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  TargetNullValue={Binding Content,
                                                  RelativeSource={RelativeSource TemplatedParent}}}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverBg" Property="Background"
                                    Value="{StaticResource InputBrush}" />
                        </Trigger>
                        <!-- Selected (not focused window) -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="HoverBg" Property="Background"
                                    Value="{StaticResource SelectionBrush}" />
                            <Setter TargetName="ActiveBar" Property="Visibility"
                                    Value="Visible" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <!-- Selected + keyboard-focused window -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected"             Value="True" />
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="HoverBg" Property="Background"
                                    Value="{StaticResource AccentBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         SidebarListBox
         ===================================================================== -->
    <Style x:Key="SidebarListBox" TargetType="ListBox">
        <Setter Property="Background"      Value="{StaticResource SidebarBrush}" />
        <Setter Property="Foreground"      Value="{StaticResource ForegroundBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding"         Value="0,4" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource SidebarListBoxItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer Padding="{TemplateBinding Padding}"
                                      Focusable="False">
                            <ItemsPresenter SnapsToDevicePixels="True" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================================
         Section header inside the sidebar (non-interactive group label)
         ===================================================================== -->
    <Style x:Key="SidebarSectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource ForegroundMutedBrush}" />
        <Setter Property="FontSize"     Value="11" />
        <Setter Property="FontWeight"   Value="SemiBold" />
        <Setter Property="Padding"      Value="12,8,12,4" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="Text"         Value="" />
    </Style>

</ResourceDictionary>
