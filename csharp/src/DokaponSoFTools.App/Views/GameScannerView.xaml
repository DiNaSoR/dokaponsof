<UserControl x:Class="DokaponSoFTools.App.Views.GameScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="Scan Game" Command="{Binding ScanGameCommand}" Margin="0,0,6,0"/>
                <Button Content="Export Report" Command="{Binding ExportReportCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Stats -->
            <Grid Grid.Column="0" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="File Types" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,4"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding FileStats}" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="100"/>
                        <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="70"/>
                        <DataGridTextColumn Header="Total Size" Binding="{Binding SizeStr}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="2" Text="Directories" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,4"/>
                <DataGrid Grid.Row="3" ItemsSource="{Binding Directories}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="70"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding TotalSize}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Right: Report -->
            <TextBox Grid.Column="2" Text="{Binding ScanReport, Mode=OneWay}"
                     IsReadOnly="True" TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     BorderThickness="0" Padding="12,8"
                     FontFamily="Consolas" FontSize="12"
                     Margin="0,8,8,8"/>
        </Grid>
    </Grid>
</UserControl>
