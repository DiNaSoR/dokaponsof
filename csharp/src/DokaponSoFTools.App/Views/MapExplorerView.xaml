<UserControl x:Class="DokaponSoFTools.App.Views.MapExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             xmlns:controls="clr-namespace:DokaponSoFTools.App.Controls"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Map file list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Map Files"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Button Content="Scan"
                            Command="{Binding ScanMapFilesCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            MinWidth="50"
                            Padding="8,3"/>
                </StackPanel>
            </Border>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding MapFiles}"
                     SelectedItem="{Binding SelectedMapFile, Mode=TwoWay}"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"
                                   Padding="8,4"
                                   Foreground="{StaticResource ForegroundBrush}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource InputBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Palette:"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Slider Minimum="0"
                            Maximum="{Binding PaletteCount}"
                            Value="{Binding SelectedPalette, Mode=TwoWay}"
                            Width="110"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"/>
                    <TextBlock Text="{Binding SelectedPalette}"
                               Foreground="{StaticResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               Width="20"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"/>

        <!-- Right: TabControl -->
        <TabControl Grid.Column="2"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    Background="{StaticResource BackgroundBrush}"
                    Foreground="{StaticResource ForegroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}">

            <!-- Atlas tab -->
            <TabItem Header="Atlas">
                <Grid>
                    <controls:ZoomPanImage ImageSource="{Binding AtlasImage}"/>
                    <TextBlock Text="No atlas image loaded"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AtlasImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>

            <!-- Map tab -->
            <TabItem Header="Map">
                <Grid>
                    <controls:ZoomPanImage ImageSource="{Binding MapImage}"/>
                    <TextBlock Text="No map image loaded"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ForegroundMutedBrush}"
                               FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MapImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>

            <!-- Records tab -->
            <TabItem Header="Records">
                <DataGrid ItemsSource="{Binding Records}"
                          Margin="4"/>
            </TabItem>

            <!-- Parts tab -->
            <TabItem Header="Parts">
                <DataGrid ItemsSource="{Binding Parts}"
                          Margin="4"/>
            </TabItem>

            <!-- Report tab -->
            <TabItem Header="Report">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource SurfaceBrush}"
                            Padding="8,4">
                        <Button Content="Export Report"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportReportCommand}"
                                HorizontalAlignment="Left"/>
                    </Border>
                    <TextBox Grid.Row="1"
                             Text="{Binding ReportText, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderThickness="0"
                             Padding="8"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
