<UserControl x:Class="DokaponSoFTools.App.Views.AssetExtractorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Paths -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Input:" VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding GamePath, Mode=OneWay}" IsReadOnly="True" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseInputCommand}"
                        Style="{StaticResource SecondaryButton}" Padding="10,4"/>

                <TextBlock Grid.Column="4" Text="Output:" VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}"/>
                <TextBox Grid.Column="5" Text="{Binding OutputPath, Mode=OneWay}" IsReadOnly="True" Margin="0,0,6,0"/>
                <Button Grid.Column="6" Content="Browse" Command="{Binding BrowseOutputCommand}"
                        Style="{StaticResource SecondaryButton}" Padding="10,4"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="Scan" Command="{Binding ScanFilesCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="0,0,6,0"/>
                <Button Content="Extract All" Command="{Binding ExtractAllCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                <TextBlock Text="Working..."
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           Foreground="{DynamicResource WarningBrush}"/>
            </StackPanel>
        </Border>

        <!-- Category tabs + preview -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Tabs by category -->
            <TabControl Grid.Column="0"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        Background="{StaticResource BackgroundBrush}">

                <TabItem Header="All">
                    <ListView ItemsSource="{Binding AllFiles}"
                              SelectedItem="{Binding SelectedFile}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding Extension}"/>
                                <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeStr}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Textures (.tex)">
                    <ListView ItemsSource="{Binding TexFiles}"
                              SelectedItem="{Binding SelectedFile}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeStr}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Sprites (.spranm)">
                    <ListView ItemsSource="{Binding SpranmFiles}"
                              SelectedItem="{Binding SelectedFile}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeStr}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Fonts (.fnt)">
                    <ListView ItemsSource="{Binding FntFiles}"
                              SelectedItem="{Binding SelectedFile}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeStr}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Maps (.mpd)">
                    <ListView ItemsSource="{Binding MpdFiles}"
                              SelectedItem="{Binding SelectedFile}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="300" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeStr}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>
            </TabControl>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <!-- Preview -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource BackgroundBrush}" CornerRadius="2">
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                    <TextBlock Grid.Row="1" Text="{Binding PreviewInfo}"
                               Margin="0,8,0,0" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource ForegroundMutedBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
