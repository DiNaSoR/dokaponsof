<Window x:Class="DokaponSoFTools.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DokaponSoFTools.App.ViewModels"
        xmlns:views="clr-namespace:DokaponSoFTools.App.Views"
        xmlns:controls="clr-namespace:DokaponSoFTools.App.Controls"
        xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
        Title="DOKAPON! Sword of Fury Tools"
        Width="1200" Height="800" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>

        <!-- DataTemplates mapping ViewModels to Views -->
        <DataTemplate DataType="{x:Type vm:AssetExtractorViewModel}">
            <views:AssetExtractorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TextToolsViewModel}">
            <views:TextToolsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VoiceToolsViewModel}">
            <views:VoiceToolsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HexEditorViewModel}">
            <views:HexEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VideoToolsViewModel}">
            <views:VideoToolsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MapExplorerViewModel}">
            <views:MapExplorerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AnimationViewerViewModel}">
            <views:AnimationViewerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameScannerViewModel}">
            <views:GameScannerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView/>
        </DataTemplate>

        <!-- Sidebar item container: preserves hover/selection visuals from
             SidebarListBoxItem but routes display through ContentPresenter so
             the ItemTemplate can render the emoji icon + name. -->
        <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="MinHeight"       Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="HoverBg" Background="Transparent" SnapsToDevicePixels="True"/>
                            <Border x:Name="ActiveBar"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Stretch"
                                    CornerRadius="0,1,1,0"
                                    Background="{DynamicResource AccentBrush}"
                                    Visibility="Collapsed"/>
                            <Border Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBg" Property="Background"
                                        Value="{DynamicResource InputBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HoverBg" Property="Background"
                                        Value="{DynamicResource SelectionBrush}"/>
                                <Setter TargetName="ActiveBar" Property="Visibility"
                                        Value="Visible"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"             Value="True"/>
                                    <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HoverBg" Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <TextBlock Text="DOKAPON! Sword of Fury Tools"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="Game Path:" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource ForegroundMutedBrush}"/>
                    <TextBox Text="{Binding GamePath, Mode=OneWay}"
                             Width="400" IsReadOnly="True" VerticalAlignment="Center"/>
                    <Button Content="Browse"
                            Command="{Binding BrowseGamePathCommand}"
                            Margin="6,0,0,0" Padding="12,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                     Style="{DynamicResource SidebarListBox}"
                     ItemContainerStyle="{StaticResource NavListBoxItem}"
                     SelectionChanged="OnNavSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="15"
                                       Width="24"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Content -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Focusable="False"/>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"/>

        <!-- Status Log -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}">
            <controls:StatusLogControl/>
        </Border>
    </Grid>
</Window>
