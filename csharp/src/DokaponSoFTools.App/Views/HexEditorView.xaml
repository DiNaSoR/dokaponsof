<UserControl x:Class="DokaponSoFTools.App.Views.HexEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Exe path + Backup -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Target Exe:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ExePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="Browse..."
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseExeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="8,0,12,0"/>
                <CheckBox Grid.Column="3"
                          Content="Create Backup"
                          IsChecked="{Binding CreateBackup, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource ForegroundBrush}"/>
            </Grid>
        </Border>

        <!-- Middle: Files panel + Patches panel -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Hex files list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Loaded Hex Files"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding HexFiles}"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsChecked}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Margin="0,6,0,0">
                    <Button Content="Add Files"
                            Command="{Binding AddHexFilesCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Margin="0,0,4,0"
                            MinWidth="70"/>
                    <Button Content="Add Folder"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddHexFolderCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Margin="0,0,4,0"
                            MinWidth="80"/>
                    <Button Content="Remove"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RemoveSelectedCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            MinWidth="65"/>
                </StackPanel>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Right: Patches DataGrid -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Patches"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           FontSize="11"
                           Margin="8,0,0,4"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Patches}"
                          Margin="0,0,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File"
                                            Binding="{Binding File}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Offset"
                                            Binding="{Binding Offset}"
                                            Width="95"/>
                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding Size}"
                                            Width="65"/>
                        <DataGridTextColumn Header="Preview"
                                            Binding="{Binding Preview}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Conflicts DataGrid (visible only when there are conflicts) -->
        <Grid Grid.Row="2"
              Margin="8,0,8,4"
              Visibility="{Binding Conflicts.Count, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="Conflicts"
                       Foreground="#FFF14C4C"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Conflicts}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type"   Binding="{Binding Type}"  Width="90"/>
                    <DataGridTextColumn Header="File 1" Binding="{Binding File1}" Width="*"/>
                    <DataGridTextColumn Header="File 2" Binding="{Binding File2}" Width="*"/>
                    <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="95"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Stats row -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,1"
                Padding="12,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" Text="Files: "/>
                <TextBlock Foreground="{StaticResource ForegroundBrush}"
                           Text="{Binding SourceFileCount}"
                           FontWeight="SemiBold"
                           Margin="0,0,16,0"/>
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" Text="Patches: "/>
                <TextBlock Foreground="{StaticResource ForegroundBrush}"
                           Text="{Binding TotalPatches}"
                           FontWeight="SemiBold"
                           Margin="0,0,16,0"/>
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" Text="Total Bytes: "/>
                <TextBlock Foreground="{StaticResource ForegroundBrush}"
                           Text="{Binding TotalBytes}"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Apply button -->
        <Border Grid.Row="4"
                Padding="12,8">
            <Button Content="Apply Patches"
                    Command="{Binding ApplyPatchesCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    HorizontalAlignment="Left"
                    MinWidth="120"/>
        </Border>
    </Grid>
</UserControl>
