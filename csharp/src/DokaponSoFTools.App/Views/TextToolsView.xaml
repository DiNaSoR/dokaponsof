<UserControl x:Class="DokaponSoFTools.App.Views.TextToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top: Exe path -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Executable:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ExePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="Browse..."
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseExeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Toolbar: Extract, Export, Import + Search -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Extract"
                        Command="{Binding ExtractTextsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="0,0,6,0"/>
                <Button Grid.Column="1"
                        Content="Export"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportTextsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="0,0,6,0"/>
                <Button Grid.Column="2"
                        Content="Import"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ImportTextsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4"
                           Text="Search:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           Margin="0,0,6,0"/>
                <TextBox Grid.Column="5"
                         Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Stats row -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" Text="Total: "/>
                <TextBlock Foreground="{StaticResource ForegroundBrush}"
                           Text="{Binding TotalEntries}"
                           FontWeight="SemiBold"
                           Margin="0,0,16,0"/>
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" Text="With Colors: "/>
                <TextBlock Foreground="{StaticResource ForegroundBrush}"
                           Text="{Binding WithColors}"
                           FontWeight="SemiBold"
                           Margin="0,0,16,0"/>
                <TextBlock Foreground="{StaticResource ForegroundMutedBrush}" Text="With Variables: "/>
                <TextBlock Foreground="{StaticResource ForegroundBrush}"
                           Text="{Binding WithVariables}"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Main content: DataGrid + Preview -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: DataGrid of text entries -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding TextEntries}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      Margin="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Offset"
                                        Binding="{Binding Offset, StringFormat=0x{0:X8}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Text"
                                        Binding="{Binding Text}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Max"
                                        Binding="{Binding MaxLength}"
                                        Width="55"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Right: Selected text preview -->
            <Grid Grid.Column="2" Margin="0,8,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Preview"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                <TextBox Grid.Row="1"
                         Text="{Binding SelectedText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         Padding="8"
                         FontFamily="Consolas"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
