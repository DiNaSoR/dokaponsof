<UserControl x:Class="DokaponSoFTools.App.Views.TextToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top: Exe path -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Executable:" VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding ExePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseExeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Button Content="Extract" Command="{Binding ExtractTextsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Margin="0,0,6,0"/>
                <Button Grid.Column="1" Content="Export" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportTextsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="Import" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ImportTextsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                <TextBlock Grid.Column="4" Text="Search:" VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,6,0"/>
                <TextBox Grid.Column="5"
                         Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Stats -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="12,5">
            <TextBlock Text="{Binding StatsText}" FontSize="12"
                       Foreground="{StaticResource ForegroundMutedBrush}"/>
        </Border>

        <!-- Main: Category tabs + Preview -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Category tabs with DataGrids -->
            <TabControl Grid.Column="0"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        Background="{StaticResource BackgroundBrush}">

                <TabItem Header="{Binding AllTabHeader}">
                    <DataGrid ItemsSource="{Binding AllEntries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Offset" Width="90"
                                Binding="{Binding Raw.Offset, StringFormat=0x{0:X8}}"/>
                            <DataGridTextColumn Header="Cat" Width="55"
                                Binding="{Binding Category}"/>
                            <DataGridTextColumn Header="Text" Width="*"
                                Binding="{Binding CleanText}"/>
                            <DataGridTextColumn Header="Used" Width="55"
                                Binding="{Binding UsagePercent, StringFormat={}{0:F0}%}"/>
                            <DataGridTextColumn Header="Max" Width="45"
                                Binding="{Binding Raw.MaxLength}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="{Binding DialogTabHeader}">
                    <DataGrid ItemsSource="{Binding DialogEntries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Offset" Width="90"
                                Binding="{Binding Raw.Offset, StringFormat=0x{0:X8}}"/>
                            <DataGridTextColumn Header="Text" Width="*"
                                Binding="{Binding CleanText}"/>
                            <DataGridTextColumn Header="Used" Width="55"
                                Binding="{Binding UsagePercent, StringFormat={}{0:F0}%}"/>
                            <DataGridTextColumn Header="Max" Width="45"
                                Binding="{Binding Raw.MaxLength}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="{Binding LabelsTabHeader}">
                    <DataGrid ItemsSource="{Binding LabelEntries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Offset" Width="90"
                                Binding="{Binding Raw.Offset, StringFormat=0x{0:X8}}"/>
                            <DataGridTextColumn Header="Text" Width="*"
                                Binding="{Binding CleanText}"/>
                            <DataGridTextColumn Header="Max" Width="45"
                                Binding="{Binding Raw.MaxLength}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="{Binding HudTabHeader}">
                    <DataGrid ItemsSource="{Binding HudEntries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Offset" Width="90"
                                Binding="{Binding Raw.Offset, StringFormat=0x{0:X8}}"/>
                            <DataGridTextColumn Header="Text" Width="*"
                                Binding="{Binding CleanText}"/>
                            <DataGridTextColumn Header="Max" Width="45"
                                Binding="{Binding Raw.MaxLength}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="{Binding SystemTabHeader}">
                    <DataGrid ItemsSource="{Binding SystemEntries}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Offset" Width="90"
                                Binding="{Binding Raw.Offset, StringFormat=0x{0:X8}}"/>
                            <DataGridTextColumn Header="Raw" Width="*"
                                Binding="{Binding Raw.Text}"/>
                            <DataGridTextColumn Header="Max" Width="45"
                                Binding="{Binding Raw.MaxLength}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Preview panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Decoded preview -->
                <TextBlock Grid.Row="0" Text="Decoded Preview" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundMutedBrush}" Margin="8,6"/>
                <TextBox Grid.Row="1"
                         Text="{Binding DecodedPreview, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         Padding="8" FontSize="14" Margin="8,0,8,4"/>

                <!-- Raw view -->
                <TextBlock Grid.Row="2" Text="Raw (binary-safe for editing)" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundMutedBrush}" Margin="8,4"/>
                <TextBox Grid.Row="3"
                         Text="{Binding RawPreview, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource BackgroundBrush}"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         Padding="8" FontFamily="Consolas" FontSize="12" Margin="8,0,8,8"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
