<UserControl x:Class="DokaponSoFTools.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DokaponSoFTools.App.Converters"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar spanning full width -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="32,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Version}"
                                   FontSize="14"
                                   Foreground="{StaticResource ForegroundMutedBrush}"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}"
                                   FontSize="14"
                                   Foreground="{StaticResource ForegroundBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Left column: Description -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="About"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="13" LineHeight="22"/>
            </Grid>
        </Border>

        <!-- Right column: Credits -->
        <Border Grid.Row="2" Grid.Column="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Credits"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundMutedBrush}"
                           Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="{Binding Credits}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="13" FontFamily="Consolas" LineHeight="22"/>
            </Grid>
        </Border>

        <!-- Bottom bar spanning full width: License, Repo, Fun -->
        <Border Grid.Row="4" Grid.ColumnSpan="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="24,12">
            <DockPanel>
                <!-- Left: License + Repo -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="License: " Foreground="{StaticResource ForegroundMutedBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding License}" Foreground="{StaticResource ForegroundBrush}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Repository: " Foreground="{StaticResource ForegroundMutedBrush}" FontSize="13"/>
                        <TextBlock FontSize="13">
                            <Hyperlink NavigateUri="{Binding Repository}"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="{StaticResource AccentBrush}">
                                <TextBlock Text="{Binding Repository}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Press F -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding PressFCommand}"
                            Padding="14,6" Margin="0,0,10,0">
                        <TextBlock Text="Press F to pay respects" FontSize="13"/>
                    </Button>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource ForegroundMutedBrush}" FontSize="12">
                        <Run Text="Respects: "/>
                        <Run Text="{Binding FPressCount, Mode=OneWay}"
                             Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
