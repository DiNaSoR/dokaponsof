<UserControl x:Class="DokaponSoFTools.App.Controls.StatusLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:DokaponSoFTools.App.Services">
    <UserControl.DataContext>
        <Binding Source="{x:Static services:StatusLogService.Instance}"/>
    </UserControl.DataContext>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,4">
            <Button x:Name="btnSave" Content="Save Log" Click="BtnSave_Click"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,4,0" Padding="10,3" MinWidth="0" MinHeight="0"/>
            <Button x:Name="btnClear" Content="Clear" Click="BtnClear_Click"
                    Style="{DynamicResource SecondaryButton}" Padding="10,3" MinWidth="0" MinHeight="0"/>
        </StackPanel>
        <ItemsControl x:Name="logItems" ItemsSource="{Binding Messages}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True">
            <ItemsControl.Template>
                <ControlTemplate TargetType="ItemsControl">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="4,1">
                        <Run Text="{Binding Timestamp, Mode=OneTime}" Foreground="#888888"/>
                        <Run Text=" "/>
                        <Run Text="{Binding Text, Mode=OneTime}" Foreground="{Binding Color, Mode=OneTime}"/>
                    </TextBlock>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
