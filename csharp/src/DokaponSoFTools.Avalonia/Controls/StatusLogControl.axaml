<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:DokaponSoFTools.App.Controls"
             xmlns:services="using:DokaponSoFTools.App.Services"
             xmlns:conv="using:DokaponSoFTools.App.Converters"
             x:Class="DokaponSoFTools.App.Controls.StatusLogControl"
             x:DataType="services:StatusLogService">

    <!-- No MenuWindow header: we build a custom title row so Save/Clear sit on
         the same line as the title. -->
    <ctrl:MenuWindow Padding="0">
        <DockPanel LastChildFill="True">

            <!-- Title row: title (left) + Save/Clear (right), same line -->
            <Border DockPanel.Dock="Top" Padding="12,6"
                    BorderBrush="{DynamicResource WindowBorderInnerBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="OUTPUT LOG" FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ForegroundMutedBrush}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button Content="Save" Click="OnSave" Padding="10,3" FontSize="12" />
                        <Button Content="Clear" Click="OnClear" Padding="10,3" FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Log entries, newest first -->
            <ScrollViewer Name="LogScroll" Padding="10,6,10,8"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="services:StatusMessage">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1">
                                <TextBlock Text="{Binding Timestamp}"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           FontSize="11"
                                           Foreground="{DynamicResource ForegroundMutedBrush}" />
                                <TextBlock Text="{Binding Text}"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{Binding Level, Converter={x:Static conv:LevelToBrushConverter.Instance}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </ctrl:MenuWindow>

</UserControl>
